{
  "name": "@loai/racore-cli",
  "version": "2.4.5",
  "description": "R'a Core standalone terminal AI coding assistant",
  "module": "src/index.tsx",
  "type": "module",
  "license": "MIT",
  "author": "R'a Core",
  "homepage": "https://www.npmjs.com/package/@loai/racore-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loayabdalslam/racore.git"
  },
  "bugs": {
    "url": "https://github.com/loayabdalslam/racore/issues"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "terminal",
    "openrouter",
    "openai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist"
  ],
  "bin": {
    "racore": "./bin/racore"
  },
  "scripts": {
    "dev": "node ../../scripts/run-bun.mjs run --watch src/index.tsx",
    "prebuild": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "node ../../scripts/run-bun.mjs build src/index.tsx src/headless.ts --outdir dist --target bun",
    "test": "node ../../scripts/run-bun.mjs test ./src/lib",
    "evals": "node evals/run-evals.mjs",
    "bump:patch": "node scripts/bump-version.mjs patch",
    "bump:minor": "node scripts/bump-version.mjs minor",
    "bump:major": "node scripts/bump-version.mjs major",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "ai": "^6.0.191",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "open": "^11.0.0",
    "opentui-spinner": "^0.0.6",
    "pretty-ms": "^9.3.0",
    "react": "^19.2.4",
    "react-router": "^7.14.0",
    "zod": "^3.25.76"
  }
}
