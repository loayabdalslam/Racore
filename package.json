{
  "name": "racore-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/cli"
  ],
  "scripts": {
    "dev:cli": "node scripts/run-bun.mjs run --watch packages/cli/src/index.tsx",
    "build": "npm run build:cli",
    "build:cli": "node scripts/run-bun.mjs run --filter @loai/racore-cli build",
    "test": "npm run test:cli",
    "test:cli": "node scripts/run-bun.mjs run --filter @loai/racore-cli test",
    "link:cli": "npm run build:cli && cd packages/cli && node ../../scripts/run-bun.mjs link",
    "version:patch": "npm version patch --workspace @loai/racore-cli --no-git-tag-version",
    "version:minor": "npm version minor --workspace @loai/racore-cli --no-git-tag-version",
    "version:major": "npm version major --workspace @loai/racore-cli --no-git-tag-version"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
